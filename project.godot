; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="AR PROJECT"
run/main_scene="uid://1ykeb6wcq7o5"
config/features=PackedStringArray("4.6", "C#", "Mobile")
boot_splash/image="uid://chbuwj2okcmw5"
config/icon="res://icon.svg"
boot_splash/minimum_display_time=2000

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[dotnet]

project/assembly_name="AR PROJECT"

[input_devices]

sensors/enable_gyroscope=true

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
viewport/transparent_background=true

[xr]

openxr/enabled=true
shaders/enabled=true
openxr/extensions/htc/passthrough=true
